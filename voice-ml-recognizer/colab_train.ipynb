    "# ── Cella 4: Genera dataset ───────────────────────────────────────────────────\n",
    "!python generate-dataset.py"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cella 5: Fine tuning ──────────────────────────────────────────────────────\n",
    "# Tutto il codice di training gira qui dentro.\n",
    "# Durata stimata su T4: 15-25 minuti.\n",
    "\n",
    "import os, json, time, random\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from dataclasses import dataclass\n",
    "from typing import Dict, List\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "from torch.optim import AdamW\n",
    "from transformers import (\n",
    "    XLMRobertaTokenizerFast, XLMRobertaModel, get_linear_schedule_with_warmup\n",
    ")\n",
    "from seqeval.metrics import f1_score as seq_f1\n",
    "\n",
    "# ── Config ────────────────────────────────────────────────────────────────────\n",
    "@dataclass\n",
    "class CFG:\n",
    "    model_name:      str   = 'xlm-roberta-base'\n",
    "    data_dir:        str   = 'data'\n",
    "    output_dir:      str   = 'output/workout_nlu'\n",
    "    max_length:      int   = 64\n",
    "    batch_size:      int   = 32\n",
    "    num_epochs:      int   = 15\n",
    "    learning_rate:   float = 2e-5\n",
    "    weight_decay:    float = 0.01\n",
    "    warmup_ratio:    float = 0.1\n",
    "    intent_weight:   float = 1.0\n",
    "    slot_weight:     float = 1.0\n",
    "    grad_clip:       float = 1.0\n",
    "    seed:            int   = 42\n",
    "    patience:        int   = 4\n",
    "    log_every_steps: int   = 50\n",
    "\n",
    "cfg = CFG()\n",
    "\n",
    "# ── Helpers ───────────────────────────────────────────────────────────────────\n",
    "def set_seed(s):\n",
    "    random.seed(s); np.random.seed(s); torch.manual_seed(s)\n",
    "    if torch.cuda.is_available(): torch.cuda.manual_seed_all(s)\n",
    "\n",
    "def load_maps(path):\n",
    "    with open(path) as f: lm = json.load(f)\n",
    "    return lm['intent2id'], lm['id2intent'], lm['tag2id'], lm['id2tag']\n",
    "\n",
    "# ── Dataset ───────────────────────────────────────────────────────────────────\n",
    "class NLUDataset(Dataset):\n",
    "    def __init__(self, path, tok, i2id, t2id, maxlen):\n",
    "        with open(path, encoding='utf-8') as f: self.data = json.load(f)\n",
    "        self.tok = tok; self.i2id = i2id; self.t2id = t2id; self.ml = maxlen\n",
    "    def __len__(self): return len(self.data)\n",
    "    def __getitem__(self, idx):\n",
    "        ex = self.data[idx]\n",
    "        words, tags = ex['words'], ex['ner_tags']\n",
    "        enc = self.tok(words, is_split_into_words=True, max_length=self.ml,\n",
    "                       padding='max_length', truncation=True, return_tensors='pt')\n",
    "        ids  = enc['input_ids'].squeeze(0)\n",
    "        mask = enc['attention_mask'].squeeze(0)\n",
    "        wids = enc.word_ids(0)\n",
    "        ner_labels, prev = [], None\n",
    "        for wid in wids:\n",
    "            if wid is None: ner_labels.append(-100)\n",
    "            elif wid != prev:\n",
    "                t = tags[wid] if wid < len(tags) else 'O'\n",
    "                ner_labels.append(self.t2id.get(t, 0))\n",
    "            else: ner_labels.append(-100)\n",
    "            prev = wid\n",
    "        return {\n",
    "            'input_ids': ids, 'attention_mask': mask,\n",
    "            'intent_label': torch.tensor(self.i2id[ex['intent']], dtype=torch.long),\n",
    "            'ner_labels':   torch.tensor(ner_labels, dtype=torch.long),\n",
    "        }\n",
    "\n",
    "# ── Modello ───────────────────────────────────────────────────────────────────\n",
    "class NLUModel(nn.Module):\n",
    "    def __init__(self, name, n_intent, n_slot, drop=0.1):\n",
    "        super().__init__()\n",
    "        self.roberta = XLMRobertaModel.from_pretrained(name)\n",
    "        h = self.roberta.config.hidden_size\n",
    "        self.intent_head = nn.Sequential(\n",
    "            nn.Dropout(drop), nn.Linear(h, h//2), nn.GELU(),\n",
    "            nn.Dropout(drop), nn.Linear(h//2, n_intent)\n",
    "        )\n",
    "        self.slot_head = nn.Sequential(nn.Dropout(drop), nn.Linear(h, n_slot))\n",
    "    def forward(self, ids, mask):\n",
    "        out = self.roberta(input_ids=ids, attention_mask=mask)\n",
    "        seq = out.last_hidden_state\n",
    "        return self.intent_head(seq[:, 0, :]), self.slot_head(seq)\n",
    "\n",
    "# ── Evaluate ──────────────────────────────────────────────────────────────────\n",
    "def evaluate(model, loader, device, id2tag):\n",
    "    model.eval()\n",
    "    correct = total = 0\n",
    "    all_pred, all_true = [], []\n",
    "    with torch.no_grad():\n",
    "        for b in loader:\n",
    "            ids  = b['input_ids'].to(device)\n",
    "            mask = b['attention_mask'].to(device)\n",
    "            il   = b['intent_label'].to(device)\n",
    "            nl   = b['ner_labels'].to(device)\n",
    "            il_log, sl_log = model(ids, mask)\n",
    "            correct += (il_log.argmax(-1) == il).sum().item(); total += il.size(0)\n",
    "            for pr, tr in zip(sl_log.argmax(-1).cpu().numpy(), nl.cpu().numpy()):\n",
    "                ps, ts = [], []\n",
    "                for p, t in zip(pr, tr):\n",
    "                    if t == -100: continue\n",
    "                    ps.append(id2tag.get(p, 'O')); ts.append(id2tag.get(t, 'O'))\n",
    "                all_pred.append(ps); all_true.append(ts)\n",
    "    acc = correct/total if total else 0\n",
    "    try: f1 = seq_f1(all_true, all_pred, zero_division=0)\n",
    "    except: f1 = 0.0\n",
    "    return {'intent_acc': acc, 'slot_f1': f1, 'combined': 0.5*acc + 0.5*f1}\n",
    "\n",
    "# ── Training ──────────────────────────────────────────────────────────────────\n",
    "set_seed(cfg.seed)\n",
    "os.makedirs(cfg.output_dir, exist_ok=True)\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Device: {device}')\n",
    "if torch.cuda.is_available():\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "    print(f'VRAM: {torch.cuda.get_device_properties(0).total_memory/1e9:.1f} GB')\n",
    "use_fp16 = torch.cuda.is_available()\n",
    "\n",
    "intent2id, id2intent, tag2id, id2tag = load_maps(os.path.join(cfg.data_dir, 'label_maps.json'))\n",
    "n_intent = len(intent2id); n_slot = len(tag2id)\n",
    "print(f'Intents: {n_intent} | NER tags: {n_slot}')\n",
    "\n",
    "tokenizer = XLMRobertaTokenizerFast.from_pretrained(cfg.model_name)\n",
    "\n",
    "mk = lambda split: NLUDataset(os.path.join(cfg.data_dir, f'{split}.json'), tokenizer, intent2id, tag2id, cfg.max_length)\n",
    "train_ds, val_ds, test_ds = mk('train'), mk('val'), mk('test')\n",
    "nw = 2\n",
    "train_loader = DataLoader(train_ds, cfg.batch_size, shuffle=True,  num_workers=nw, pin_memory=True)\n",
    "val_loader   = DataLoader(val_ds,   cfg.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\n",
    "test_loader  = DataLoader(test_ds,  cfg.batch_size, shuffle=False, num_workers=nw, pin_memory=True)\n",
    "print(f'Train: {len(train_ds)} | Val: {len(val_ds)} | Test: {len(test_ds)}')\n",
    "\n",
    "model = NLUModel(cfg.model_name, n_intent, n_slot).to(device)\n",
    "print(f'Parametri: {sum(p.numel() for p in model.parameters()):,}')\n",
    "\n",
    "optimizer = AdamW([\n",
    "    {'params': model.roberta.parameters(),     'lr': cfg.learning_rate},\n",
    "    {'params': model.intent_head.parameters(), 'lr': cfg.learning_rate * 5},\n",
    "    {'params': model.slot_head.parameters(),   'lr': cfg.learning_rate * 5},\n",
    "], weight_decay=cfg.weight_decay)\n",
    "\n",
    "total_steps  = len(train_loader) * cfg.num_epochs\n",
    "scheduler    = get_linear_schedule_with_warmup(optimizer, int(total_steps*cfg.warmup_ratio), total_steps)\n",
    "ic = nn.CrossEntropyLoss()\n",
    "sc = nn.CrossEntropyLoss(ignore_index=-100)\n",
    "scaler = torch.amp.GradScaler('cuda', enabled=use_fp16)\n",
    "\n",
    "print(f'\\n{\"=\"*60}')\n",
    "print(f'Training {cfg.num_epochs} epoche | batch {cfg.batch_size} | fp16={use_fp16}')\n",
    "print(f'{\"=\"*60}\\n')\n",
    "\n",
    "best = 0.0; pat = 0\n",
    "for epoch in range(1, cfg.num_epochs + 1):\n",
    "    model.train()\n",
    "    li_tot = ls_tot = 0.0\n",
    "    t0 = time.time()\n",
    "    for step, b in enumerate(train_loader, 1):\n",
    "        ids  = b['input_ids'].to(device)\n",
    "        mask = b['attention_mask'].to(device)\n",
    "        il   = b['intent_label'].to(device)\n",
    "        nl   = b['ner_labels'].to(device)\n",
    "        optimizer.zero_grad()\n",
    "        with torch.amp.autocast('cuda', enabled=use_fp16):\n",
    "            il_log, sl_log = model(ids, mask)\n",
    "            li = ic(il_log, il)\n",
    "            ls = sc(sl_log.view(-1, n_slot), nl.view(-1))\n",
    "            loss = cfg.intent_weight * li + cfg.slot_weight * ls\n",
    "        scaler.scale(loss).backward()\n",
    "        scaler.unscale_(optimizer)\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), cfg.grad_clip)\n",
    "        scaler.step(optimizer); scaler.update(); scheduler.step()\n",
    "        li_tot += li.item(); ls_tot += ls.item()\n",
    "        if step % cfg.log_every_steps == 0:\n",
    "            print(f'  Ep {epoch:2d} step {step:4d}/{len(train_loader)} | li={li_tot/step:.4f} ls={ls_tot/step:.4f}')\n",
    "\n",
    "    m = evaluate(model, val_loader, device, id2tag)\n",
    "    print(f'Epoch {epoch:2d} ({time.time()-t0:.0f}s) — Val: intent={m[\"intent_acc\"]:.4f} slot_f1={m[\"slot_f1\"]:.4f} combined={m[\"combined\"]:.4f}')\n",
    "\n",
    "    if m['combined'] > best:\n",
    "        best = m['combined']; pat = 0\n",
    "        torch.save({'model_state': model.state_dict(), 'intent2id': intent2id, 'tag2id': tag2id, 'epoch': epoch},\n",
    "                   os.path.join(cfg.output_dir, 'best_model.pt'))\n",
    "        print(f'  [BEST] {best:.4f} salvato')\n",
    "    else:\n",
    "        pat += 1\n",
    "        print(f'  Patience {pat}/{cfg.patience}')\n",
    "        if pat >= cfg.patience:\n",
    "            print('Early stopping.'); break\n",
    "    print()\n",
    "\n",
    "# Test finale\n",
    "ckpt = torch.load(os.path.join(cfg.output_dir, 'best_model.pt'), map_location=device)\n",
    "model.load_state_dict(ckpt['model_state'])\n",
    "tm = evaluate(model, test_loader, device, id2tag)\n",
    "print(f'\\nTEST -> intent_acc={tm[\"intent_acc\"]:.4f} slot_f1={tm[\"slot_f1\"]:.4f} combined={tm[\"combined\"]:.4f}')\n",
    "with open(os.path.join(cfg.output_dir, 'results.json'), 'w') as f:\n",
    "    json.dump({'best_val': best, 'test': tm}, f, indent=2)\n",
    "print('Training completato!')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cella 6: Export ONNX ──────────────────────────────────────────────────────\n",
    "import os\n",
    "\n",
    "model.eval(); model.cpu()\n",
    "dummy = tokenizer(['add bench press 3 sets 10 reps'], is_split_into_words=False,\n",
    "                   max_length=64, padding='max_length', truncation=True, return_tensors='pt')\n",
    "\n",
    "onnx_path = os.path.join(cfg.output_dir, 'workout_nlu.onnx')\n",
    "with torch.no_grad():\n",
    "    torch.onnx.export(\n",
    "        model, (dummy['input_ids'], dummy['attention_mask']), onnx_path,\n",
    "        input_names=['input_ids', 'attention_mask'],\n",
    "        output_names=['intent_logits', 'slot_logits'],\n",
    "        dynamic_axes={'input_ids': {0:'b',1:'s'}, 'attention_mask': {0:'b',1:'s'},\n",
    "                      'intent_logits': {0:'b'}, 'slot_logits': {0:'b',1:'s'}},\n",
    "        opset_version=17,\n",
    "    )\n",
    "print(f'ONNX: {onnx_path} ({os.path.getsize(onnx_path)/1e6:.1f} MB)')\n",
    "\n",
    "try:\n",
    "    from onnxruntime.quantization import quantize_dynamic, QuantType\n",
    "    q = os.path.join(cfg.output_dir, 'workout_nlu_int8.onnx')\n",
    "    quantize_dynamic(onnx_path, q, weight_type=QuantType.QInt8)\n",
    "    print(f'ONNX INT8: {q} ({os.path.getsize(q)/1e6:.1f} MB)')\n",
    "except Exception as e:\n",
    "    print(f'Quantizzazione saltata: {e}')\n",
    "\n",
    "model.to(device)"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ── Cella 7: Demo inference ───────────────────────────────────────────────────\n",
    "model.eval()\n",
    "\n",
    "sentences = [\n",
    "    ('it', 'aggiungi bench press 3 x 10 a cedimento'),\n",
    "    ('it', 'aggiungi squat 4 serie da 8 e push up 3 x 15 dropset'),\n",
    "    ('it', 'aggiungi deadlift 3 x 5 e lat machine 4 x 10 e crunch 3 x 20 a cedimento'),\n",
    "    ('it', 'fatto deadlift 5 reps 140 kg'),\n",
    "    ('it', 'rimuovi lat machine'),\n",
    "    ('en', 'add bench press 3 sets of 8 reps 80 kg to failure'),\n",
    "    ('en', 'add pull ups 4 x 8 and dips 3 x 12 then leg raises 3 x 20'),\n",
    "    ('en', 'done bench press 8 reps 80 kg'),\n",
    "    ('it', 'quanto riposo tra le serie'),\n",
    "]\n",
    "\n",
    "id2intent_local = {v: k for k, v in intent2id.items()}\n",
    "id2tag_local    = {v: k for k, v in tag2id.items()}\n",
    "\n",
    "for lang, text in sentences:\n",
    "    words = text.split()\n",
    "    enc = tokenizer(words, is_split_into_words=True, max_length=64,\n",
    "                    padding='max_length', truncation=True, return_tensors='pt').to(device)\n",
    "    with torch.no_grad():\n",
    "        il_log, sl_log = model(enc['input_ids'], enc['attention_mask'])\n",
    "\n",
    "    probs  = torch.softmax(il_log, -1)[0]\n",
    "    intent = id2intent_local[probs.argmax().item()]\n",
    "    conf   = probs.max().item()\n",
    "\n",
    "    slot_preds = sl_log.argmax(-1)[0].cpu().tolist()\n",
    "    seen = {}\n",
    "    for pos, wid in enumerate(enc.word_ids(0)):\n",
    "        if wid is not None and wid not in seen:\n",
    "            seen[wid] = id2tag_local.get(slot_preds[pos], 'O')\n",
    "\n",
    "    entities = {}\n",
    "    cur_type, cur_words = None, []\n",
    "    for wid in sorted(seen):\n",
    "        tag = seen[wid]\n",
    "        if tag.startswith('B-'):\n",
    "            if cur_type: entities.setdefault(cur_type, []).append(' '.join(cur_words))\n",
    "            cur_type, cur_words = tag[2:], [words[wid]]\n",
    "        elif tag.startswith('I-') and cur_type:\n",
    "            cur_words.append(words[wid])\n",
    "        else:\n",
    "            if cur_type: entities.setdefault(cur_type, []).append(' '.join(cur_words))\n",
    "            cur_type, cur_words = None, []\n",
    "    if cur_type: entities.setdefault(cur_type, []).append(' '.join(cur_words))\n",
    "\n",
    "    print(f'[{lang}] \"{text}\"')\n",
    "    print(f'  Intent:   {intent} ({conf:.1%})')\n",
    "    print(f'  Entities: {entities}')\n",
    "    print()"
   ],
   "execution_count": null,
   "outputs": []
  },
